{
  "software": "Fjord VI Embarque",
  "version": "1.3.7",
  "author": "Sebastián Isenberg",
  "institution": "Yacht Club Argentino",
  "boat": "Fjord VI",
  "purpose": "Sistema web para reservas, embarque, check-in, cierre de navegación y liquidación operativa del Fjord VI.",
  "runtime_files": [
    "main.py",
    "templates/",
    "static/",
    "requirements.txt",
    "Procfile",
    "Dockerfile",
    "docker-compose.yml",
    "render.yaml",
    "start.sh"
  ],
  "core_modules": [
    "Login y roles",
    "Socio",
    "Capitán",
    "Administración",
    "Reservas y lista de espera",
    "Participaciones protocolares",
    "Cierre y liquidación",
    "Fichas vigentes/anuladas",
    "Exportaciones CSV/PDF",
    "Auditoría operativa"
  ],
  "latest_features": [
    "Pantalla amable de sesión vencida",
    "Participación protocolar sin cargo",
    "Reserva institucional por salida",
    "Capacidad operativa editable",
    "Nombre visible permanente en protocolares",
    "Login con control mostrar/ocultar clave integrado"
  ],
  "repository_profile": "production-clean",
  "notes": "Este ZIP elimina auditorías transitorias y residuos de desarrollo. Las auditorías históricas no son necesarias para ejecución ni deploy.",
  "security_features": [
    "must_change_password",
    "cambio_obligatorio_clave_inicial",
    "bloqueo_clave_temporal_demo1234",
    "validacion_doble_clave",
    "hash_pbkdf2_sha256"
  ],
  "fixes": [
    "onclick_sin_escape_invalido",
    "ojos_clave_funcionales",
    "funcion_toggle_en_head"
  ]
}